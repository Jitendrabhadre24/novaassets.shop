/**
 * NovaAssets Security Rules
 * 
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model designed for a premium digital assets platform. 
 * Security is rooted in Firebase Authentication, where access to data is primarily determined 
 * by the user's unique identity (UID) matching the path structure of the database.
 * 
 * Data Structure:
 * All user-specific data is organized hierarchically. User profiles are stored at the root 
 * (/users/{userId}), and their specific product requests are nested as a subcollection 
 * (/users/{userId}/productRequests/{requestId}). This structure ensures that a user's 
 * data is naturally siloed.
 * 
 * Key Security Decisions:
 * 1. Path-Based Authorization: The UID from Firebase Auth is used as the document ID for 
 *    user profiles, making ownership checks extremely performant and reliable.
 * 2. Authorization Independence: Critical fields like 'userId' are denormalized into 
 *    subcollection documents. This allows the rules to verify ownership and relational 
 *    integrity without performing expensive 'get()' lookups on parent documents.
 * 3. Restricted Discovery: The rules explicitly disallow listing the global 'users' 
 *    collection to prevent user enumeration and protect privacy.
 * 4. Prototyping Flexibility: While authorization is strictly enforced (who can access), 
 *    the specific data schema (types and extra fields) is kept flexible to allow for 
 *    rapid iteration of the NovaAssets feature set.
 * 
 * Denormalization for Authorization:
 * The 'ProductRequest' entity includes a 'userId' field that must match the path's '{userId}'. 
 * This ensures that even if a request is moved or queried independently, its ownership 
 * remains cryptographically tied to the authenticated user.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /**
     * @description Basic check to see if the request is coming from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Combined check for ownership and document existence for write operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the User profile collection.
     * @path /users/{userId}
     * @allow (get) If the auth UID matches the document ID.
     * @deny (list) Global listing of users is forbidden for privacy.
     * @principle Enforces path-based ownership and self-creation of user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for product requests made by users.
     * @path /users/{userId}/productRequests/{productRequestId}
     * @allow (list) User can list their own product requests in the dashboard.
     * @deny (create) Mismatched userId in data vs path.
     * @principle Validates relational integrity by ensuring the internal userId matches the owner path.
     */
    match /users/{userId}/productRequests/{productRequestId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }
  }
}